// Prisma schema – An Phát Industry CMS

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  shortDescription String
  description      String
  category         String   @default("sua-chua-chung")
  categoryLabel    String   @default("Sửa Chữa Chung")
  image            String
  highlights       String   @default("[]") // JSON array of strings
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @default("")
  author      String   @default("An Phát Industry")
  publishedAt DateTime @default(now())
  category    String   @default("kinh-nghiem")
  image       String
  tags        String   @default("[]") // JSON array of strings
  readingTime Int      @default(5)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String // JSON value
  updatedAt DateTime @updatedAt
}
